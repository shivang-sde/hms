# Database Configuration
DB_USER=hms_user
DB_PASSWORD=hms_password
DB_NAME=hms

# Database URL - Use service name for Docker internal resolution
DATABASE_URL=postgresql://${DB_USER}:${DB_PASSWORD}@hms-db:5432/${DB_NAME}


STAFF_EMAIL=staff_email
ADMIN_EMAIL=admin_email
STAFF_PASSWORD=staff_password
ADMIN_PASSWORD=admin_password
STAFF_NAME=staff_name
ADMIN_NAME=admin_name

# App Configuration
# NEXT_PUBLIC_APP_URL=app.yourdomain.com  # Your actual domain (temporary IP if no domain)

NEXTAUTH_URL=localhost:3000
NEXTAUTH_SECRET=your_nextauth_secret_key_here

# Node Environment
NODE_ENV=production

# Session Configuration
SESSION_INACTIVITY_TIMEOUT=1800000 # 30 minutes in ms
SESSION_CHECK_INTERVAL=10000 # 10 seconds in ms


SESSION_INACTIVITY_TIMEOUT=1800000
SESSION_CHECK_INTERVAL=10000

# Optional: If you need to test without domain
# NEXT_PUBLIC_APP_URL=your-server-ip  # Use IP temporarily
# NEXTAUTH_URL=http://your-server-ip:3001  # For testing without Traefik