generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Master Data ────────────────────────────────────────────────────────────────

model City {
  id        String   @id @default(cuid())
  name      String
  state     String
  country   String   @default("India")
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  holdings Holding[]
  clients  Client[]
  locationSuggestions LocationSuggestion[]

  @@unique([name, state])
  @@map("cities")
}

model HoldingType {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  holdings Holding[]

  @@map("holding_types")
}

model HsnCode {
  id          String   @id @default(cuid())
  code        String   @unique
  description String
  gstRate     Decimal  @db.Decimal(5, 2)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  holdings Holding[]
  invoices Invoice[]

  @@map("hsn_codes")
}

// ─── Holdings ───────────────────────────────────────────────────────────────────

model Holding {
  id                String        @id @default(cuid())
  code              String        @unique
  name              String
  address           String
  latitude          Decimal?      @db.Decimal(10, 7)
  longitude         Decimal?      @db.Decimal(10, 7)
  width             Decimal       @db.Decimal(10, 2)
  height            Decimal       @db.Decimal(10, 2)
  totalArea         Decimal       @db.Decimal(10, 2)
  illumination      Illumination  @default(NON_LIT)
  facing            String?
  landmark          String?
  status            HoldingStatus @default(AVAILABLE)
  maintenanceCycle  Int           @default(90) // days
  notes             String?

  cityId        String
  holdingTypeId String
  hsnCodeId     String

  city        City        @relation(fields: [cityId], references: [id])
  holdingType HoldingType @relation(fields: [holdingTypeId], references: [id])
  hsnCode     HsnCode     @relation(fields: [hsnCodeId], references: [id])

  ownershipContracts OwnershipContract[]
  bookings           Booking[]
  tasks              Task[]
  inspections        Inspection[]
  maintenanceRecords MaintenanceRecord[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("holdings")
}

enum Illumination {
  LIT
  NON_LIT
  DIGITAL
}

enum HoldingStatus {
  AVAILABLE
  BOOKED
  UNDER_MAINTENANCE
  INACTIVE
}

// ─── Ownership Contracts ────────────────────────────────────────────────────────

model OwnershipContract {
  id              String        @id @default(cuid())
  contractNumber  String        @unique
  ownerName       String
  ownerType       OwnerType
  ownerContact    String?
  ownerEmail      String?
  ownerAddress    String?
  rentAmount      Decimal       @db.Decimal(12, 2)
  rentCycle       RentCycle     @default(MONTHLY)
  startDate       DateTime
  endDate         DateTime
  securityDeposit Decimal?      @db.Decimal(12, 2)
  status          ContractStatus @default(ACTIVE)
  notes           String?

  holdingId String
  holding   Holding @relation(fields: [holdingId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("ownership_contracts")
}

enum OwnerType {
  GOVERNMENT
  MUNICIPAL
  VILLAGE_PANCHAYAT
  PRIVATE
}

enum RentCycle {
  MONTHLY
  QUARTERLY
  HALF_YEARLY
  YEARLY
}

enum ContractStatus {
  ACTIVE
  EXPIRED
  TERMINATED
  PENDING
}

// ─── Clients ────────────────────────────────────────────────────────────────────

model Client {
  id            String   @id @default(cuid())
  name          String
  contactPerson String
  email         String?
  phone         String
  gstNumber     String?
  panNumber     String?
  address       String
  isActive      Boolean  @default(true)

  cityId String?
  city   City?   @relation(fields: [cityId], references: [id])

  bookings Booking[]
  invoices Invoice[]
  receipts Receipt[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("clients")
}

// ─── Bookings ───────────────────────────────────────────────────────────────────

model Booking {
  id            String        @id @default(cuid())
  bookingNumber String        @unique
  startDate     DateTime
  endDate       DateTime
  monthlyRate   Decimal       @db.Decimal(12, 2)
  totalAmount   Decimal       @db.Decimal(12, 2)
  billingCycle  BillingCycle  @default(MONTHLY)
  status        BookingStatus @default(CONFIRMED)
  notes         String?

  clientId  String
  holdingId String

  client  Client  @relation(fields: [clientId], references: [id])
  holding Holding @relation(fields: [holdingId], references: [id])

  advertisements Advertisement[]
  invoices       Invoice[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("bookings")
}

enum BillingCycle {
  MONTHLY
  QUARTERLY
  HALF_YEARLY
  YEARLY
}

enum BookingStatus {
  CONFIRMED
  ACTIVE
  COMPLETED
  CANCELLED
}

// ─── Advertisements ─────────────────────────────────────────────────────────────

model Advertisement {
  id                     String     @id @default(cuid())
  campaignName           String
  brandName              String
  artworkDescription     String?
  artworkUrl             String?
  freeInstallationDays   Int        @default(0)
  installationDate       DateTime?
  removalDate            DateTime?
  status                 AdStatus   @default(PENDING)
  notes                  String?

  bookingId String
  booking   Booking @relation(fields: [bookingId], references: [id])

  tasks Task[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("advertisements")
}

enum AdStatus {
  PENDING
  INSTALLED
  ACTIVE
  REMOVED
  COMPLETED
}

// ─── Task System ────────────────────────────────────────────────────────────────

model Task {
  id              String     @id @default(cuid())
  title           String
  description     String?
  taskType        TaskType
  priority        Priority   @default(MEDIUM)
  status          TaskStatus @default(PENDING)
  scheduledDate   DateTime
  completedDate   DateTime?
  assignedToId      String?
  assignedTo        User?          @relation("AssignedToUser", fields: [assignedToId], references: [id])
  estimatedCost   Decimal?   @db.Decimal(12, 2)
  actualCost      Decimal?   @db.Decimal(12, 2)
  notes           String?

  holdingId       String?
  advertisementId String?

  holding       Holding?       @relation(fields: [holdingId], references: [id])
  advertisement Advertisement? @relation(fields: [advertisementId], references: [id])

  executions      TaskExecution[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("tasks")
}

model TaskExecution {
  id              String           @id @default(cuid())
  taskId          String
  task            Task             @relation(fields: [taskId], references: [id])
  
  performedById   String
  performedBy     User             @relation(fields: [performedById], references: [id])
  
  status          TaskStatus?
  condition       HoldingCondition
  remarks         String?
  
  // Proof
  latitude        Decimal          @db.Decimal(10, 7)
  longitude       Decimal          @db.Decimal(10, 7)
  
  frontViewUrl    String
  leftViewUrl     String
  rightViewUrl    String
  
  createdAt       DateTime @default(now())
  
  @@map("task_executions")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  password      String
  plainPassword String?
  role          UserRole  @default(STAFF)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  taskExecutions TaskExecution[]
  assignedTasks  Task[] @relation("AssignedToUser")

  @@map("users")
}

enum UserRole {
  ADMIN
  STAFF
}

enum TaskType {
  INSTALLATION
  MOUNTING
  MAINTENANCE
  INSPECTION
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum TaskStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

// ─── Inspections ────────────────────────────────────────────────────────────────

model Inspection {
  id              String           @id @default(cuid())
  inspectionDate  DateTime
  inspectorName   String
  condition       HoldingCondition
  illuminationOk  Boolean          @default(true)
  structureOk     Boolean          @default(true)
  visibilityOk    Boolean          @default(true)
  remarks         String?

  holdingId String
  holding   Holding @relation(fields: [holdingId], references: [id])

  photos InspectionPhoto[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("inspections")
}

model InspectionPhoto {
  id           String @id @default(cuid())
  url          String
  caption      String?
  inspectionId String

  inspection Inspection @relation(fields: [inspectionId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@map("inspection_photos")
}

enum HoldingCondition {
  EXCELLENT
  GOOD
  FAIR
  POOR
  CRITICAL
}

// ─── Maintenance ────────────────────────────────────────────────────────────────

model MaintenanceRecord {
  id              String            @id @default(cuid())
  maintenanceType MaintenanceType
  description     String
  cost            Decimal           @db.Decimal(12, 2)
  performedDate   DateTime
  performedBy     String
  status          MaintenanceStatus @default(COMPLETED)
  notes           String?

  holdingId String
  holding   Holding @relation(fields: [holdingId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("maintenance_records")
}

enum MaintenanceType {
  PAINTING
  STRUCTURAL_REPAIR
  ELECTRICAL
  CLEANING
  REPLACEMENT
  OTHER
}

enum MaintenanceStatus {
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

// ─── Billing ────────────────────────────────────────────────────────────────────

model Invoice {
  id              String        @id @default(cuid())
  invoiceNumber   String        @unique
  invoiceDate     DateTime
  dueDate         DateTime
  subtotal        Decimal       @db.Decimal(12, 2)
  cgstRate        Decimal       @db.Decimal(5, 2)
  sgstRate        Decimal       @db.Decimal(5, 2)
  igstRate        Decimal       @db.Decimal(5, 2) @default(0)
  cgstAmount      Decimal       @db.Decimal(12, 2)
  sgstAmount      Decimal       @db.Decimal(12, 2)
  igstAmount      Decimal       @db.Decimal(12, 2) @default(0)
  totalAmount     Decimal       @db.Decimal(12, 2)
  paidAmount      Decimal       @db.Decimal(12, 2) @default(0)
  status          InvoiceStatus @default(DRAFT)
  notes           String?

  clientId  String
  bookingId String
  hsnCodeId String

  client  Client  @relation(fields: [clientId], references: [id])
  booking Booking @relation(fields: [bookingId], references: [id])
  hsnCode HsnCode @relation(fields: [hsnCodeId], references: [id])

  receipts Receipt[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("invoices")
}

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  PARTIALLY_PAID
  OVERDUE
  CANCELLED
}

// ─── Receipts ───────────────────────────────────────────────────────────────────

model Receipt {
  id            String        @id @default(cuid())
  receiptNumber String        @unique
  receiptDate   DateTime
  amount        Decimal       @db.Decimal(12, 2)
  paymentMode   PaymentMode
  referenceNo   String?
  notes         String?

  clientId  String
  invoiceId String

  client  Client  @relation(fields: [clientId], references: [id])
  invoice Invoice @relation(fields: [invoiceId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("receipts")
}

enum PaymentMode {
  CASH
  CHEQUE
  NEFT
  RTGS
  UPI
  CARD
  OTHER
}

// ─── Location Suggestions ──────────────────────────────────────────────────────

model LocationSuggestion {
  id              String           @id @default(cuid())
  
  // Location
  address         String
  cityId          String
  city            City             @relation(fields: [cityId], references: [id])
  latitude        Decimal?         @db.Decimal(10, 7)
  longitude       Decimal?         @db.Decimal(10, 7)
  landmark        String?
  
  // Proposal Details
  description     String?
  photos          String[]
  proposedRent    Decimal?         @db.Decimal(12, 2)
  
  // Contact (Owner of the place)
  ownerName       String?
  ownerPhone      String?
  
  status          SuggestionStatus @default(PENDING)
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  @@map("location_suggestions")
}

enum SuggestionStatus {
  PENDING
  ACCEPTED
  REJECTED
}
